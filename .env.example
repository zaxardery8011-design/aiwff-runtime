# Runtime environment variables
# Copy this file to .env — npm install is optional (zero external dependencies)

PORT=3100

# Telegram Bot（選填，不填就只有 WebUI）
TG_BOT_TOKEN=
# Required when TG_BOT_TOKEN is set.
ADMIN_TG_CHAT_ID=

# Worker mode: public default is mock. Enable real Claude explicitly.
CLAUDE_CMD=claude
MOCK_WORKER=1
ENABLE_REAL_CLAUDE_WORKER=
# Adds --dangerously-skip-permissions to claude --print.
CLAUDE_BYPASS_APPROVALS=
