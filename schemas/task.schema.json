{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/aiwff-runtime/task.schema.json",
  "title": "AIWFF Runtime Task",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "instruction", "status", "created_at", "updated_at"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "done", "failed", "blocked"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_path": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "timeout_sec": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    },
    "blocked_reason": {
      "type": "string"
    }
  }
}
